# Root .gitignore (multi-project repo)
# Add project-specific ignores in each project's own .gitignore if needed.

# --- OS / filesystem noise ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*.tmp

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Environment / secrets ---
.env
.env.*
!.env*.example
*.pem
*.key
*.p12
*.pfx
*.jks

# --- Node / JS / TS ---
node_modules/
bower_components/
coverage/
dist/
build/
out/
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/
.vite/
.eslintcache
.stylelintcache
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
ENV/

# --- .NET ---
bin/
obj/

# --- Java / Gradle / Maven ---
target/
.gradle/
*.class

# --- C/C++ compiled outputs ---
*.o
*.obj
*.exe
*.dll
*.pdb
